{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@src/*": ["./src/*"]
    },
    "useUnknownInCatchVariables": false,
    "types": ["node"]
  },
  "ts-node": {
    "swc": false,
    "require": ["tsconfig-paths/register", "dotenv/config"],
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": ["src/public/*"]
}
