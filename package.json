{
  "name": "sse-query-invalidator-workspace",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "install:all": "pnpm install",
    "build": "pnpm --filter restale-kit run build",
    "typecheck": "node node_modules/typescript-7/bin/tsc -p restale-kit/tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "validate": "pnpm run typecheck && pnpm run lint",
    "dev:client": "pnpm --filter @restale-kit-example/react-query run dev",
    "dev:swr": "pnpm --filter @restale-kit-example/react-swr run dev",
    "dev:express": "pnpm --filter @restale-kit-example/express run dev",
    "dev:hono": "pnpm --filter @restale-kit-example/hono run dev",
    "dev:fastify": "pnpm --filter @restale-kit-example/fastify run dev",
    "dev:node": "pnpm --filter @restale-kit-example/node run dev",
    "example": "node scripts/run-example.mjs"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-7": "npm:typescript@7.0.2",
    "typescript-eslint": "^8.63.0"
  }
}
