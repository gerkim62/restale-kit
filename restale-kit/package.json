{
  "name": "restale-kit",
  "version": "0.0.1",
  "description": "Minimal library to invalidate client-side queries via SSE",
  "type": "module",
  "exports": {
    ".":               { "types": "./dist/server-core/index.d.ts",    "import": "./dist/server-core/index.js" },
    "./shared":        { "types": "./dist/shared/index.d.ts",         "import": "./dist/shared/index.js" },
    "./client-core":   { "types": "./dist/client-core/index.d.ts",    "import": "./dist/client-core/index.js" },
    "./node":          { "types": "./dist/node/index.d.ts",           "import": "./dist/node/index.js" },
    "./fetch":         { "types": "./dist/fetch/index.d.ts",          "import": "./dist/fetch/index.js" },
    "./react":         { "types": "./dist/react/index.d.ts",          "import": "./dist/react/index.js" },
    "./tanstack-query": { "types": "./dist/tanstack-query/index.d.ts", "import": "./dist/tanstack-query/index.js" },
    "./pubsub-redis":  { "types": "./dist/pubsub-redis/index.d.ts",   "import": "./dist/pubsub-redis/index.js" },
    "./pubsub-ably":   { "types": "./dist/pubsub-ably/index.d.ts",    "import": "./dist/pubsub-ably/index.js" },
    "./pubsub-pusher": { "types": "./dist/pubsub-pusher/index.d.ts",  "import": "./dist/pubsub-pusher/index.js" }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "@tanstack/react-query": "^5.0.0",
    "ioredis": ">=4",
    "ably": ">=1",
    "pusher": ">=5"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "ably": {
      "optional": true
    },
    "pusher": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "@tanstack/react-query": "^5.0.0",
    "ioredis": "^5.4.1",
    "ably": "^2.3.2",
    "pusher": "^5.2.0"
  }
}
