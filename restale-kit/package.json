      "optional": true
    },
    "pusher": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "@tanstack/react-query": "^5.0.0",
    "swr": "^2.4.0",
    "ioredis": "^5.4.1",
    "ably": "^2.3.2",
    "pusher": "^5.2.0"
